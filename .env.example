# ─────────────────────────────────────────────────────────────
# Medication Tracker — biến môi trường
# Copy file này thành .env (local) và điền vào Vercel > Settings > Environment Variables
# ─────────────────────────────────────────────────────────────

# --- Supabase Postgres (Prisma) ---
# Supabase > Project Settings > Database > Connection string
# DATABASE_URL: dùng connection pooler (port 6543) cho app serverless
# DIRECT_URL:   dùng direct connection (port 5432) cho prisma migrate
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# --- Supabase Storage (upload hồ sơ y tế: đơn thuốc, PDF, ảnh, EEG/MRI/CT) ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role_key..."
SUPABASE_STORAGE_BUCKET="medical-documents"

# --- Múi giờ (dùng cho cron 23:00 và tính ngày) ---
APP_TIMEZONE="Asia/Ho_Chi_Minh"

# --- Web Push (VAPID) ---
# Tạo bằng: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# --- Telegram (nhắc thiếu liều) ---
# Tạo bot với @BotFather -> lấy token; lấy chat id qua @userinfobot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Email (tùy chọn, SMTP) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Medication Tracker <you@example.com>"
NOTIFY_EMAIL_TO=""

# --- Bảo vệ cron endpoint (Vercel Cron gửi header Authorization: Bearer <CRON_SECRET>) ---
CRON_SECRET=""
